# WITS Agent Atelier environment template
# Copy this file to .env and fill values locally. Never commit .env.

# Backend mode: local uses a model deployment plus tool calls; foundry routes directly to Foundry agents.
AGENT_KIND=foundry

# Azure AI Foundry project and default router/agent.
# Endpoint format: https://<account>.services.ai.azure.com/api/projects/<project>
AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-project-endpoint>
AZURE_AI_PROJECT_AGENT_NAME=<your-default-agent-name>
# Optional: pin a published Foundry agent version.
# AZURE_AI_PROJECT_AGENT_VERSION=1.0

# Model deployment used by local mode and backend fallback client.
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=<your-model-deployment-name>

# Optional legacy Azure OpenAI chat mode. Prefer Entra ID where possible.
# AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=<your-chat-deployment-name>
# AZURE_OPENAI_ENDPOINT=https://<resource>.cognitiveservices.azure.com/openai/deployments/<deployment>/chat/completions?api-version=<api-version>
# AZURE_OPENAI_API_KEY=<do-not-commit-real-api-key>

# Backend HTTP server.
HOST=0.0.0.0
PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend proxy target. Docker frontend uses host.docker.internal by default in docker-compose.frontend.yml.
AG_UI_ENDPOINT=http://localhost:8000/ag-ui

# File attachment slots passed to Foundry structured_inputs.
FOUNDRY_FILE_SLOT_COUNT=5

# Logging. Set LOG_LEVEL=DEBUG only for local troubleshooting.
LOG_LEVEL=INFO
# ENABLE_DEBUG_LOGGING=1

# Optional Foundry agent creation / MCP configuration used by create_or_update_agent_v3.py.
# FOUNDRY_MODEL_DEPLOYMENT=<model-deployment-name>
# FOUNDRY_AGENT_NAME=<agent-name-to-create-or-update>
# FOUNDRY_ENABLE_MCP=true
# FOUNDRY_MCP_SERVER_URL=https://api.fabric.microsoft.com/v1/mcp/powerbi
# FOUNDRY_MCP_PROJECT_CONNECTION_ID=<remote-tool-connection-id>
# FOUNDRY_MCP_PROJECT_CONNECTION_NAME=<remote-tool-connection-name>
# FOUNDRY_MCP_PROJECT_CONNECTION_AUTO_RESOLVE=true
# FOUNDRY_MCP_ALLOWED_TOOLS=listWorkspaces,listSemanticModels,executeQueries
# FOUNDRY_MCP_REQUIRE_APPROVAL=never
# FOUNDRY_MCP_FAIL_IF_UNAUTH=true
# FOUNDRY_MCP_USE_AZD_TOKEN=false
# FOUNDRY_MCP_AUTH_SCOPE=https://api.fabric.microsoft.com/.default
# FOUNDRY_MCP_AUTH_TENANT_ID=<tenant-id>
# FOUNDRY_MCP_AUTHORIZATION=<do-not-commit-bearer-token>
# FOUNDRY_MCP_HEADERS_JSON={}

# Optional Power BI / Fabric MCP local test utilities.
# FABRIC_POWERBI_MCP_URL=https://api.fabric.microsoft.com/v1/mcp/powerbi
# FABRIC_POWERBI_MCP_SCOPE=https://api.fabric.microsoft.com/.default
# FABRIC_ARTIFACT_ID=<semantic-model-or-artifact-id>
# FABRIC_SEMANTIC_MODEL_ID=<semantic-model-id>
# MCP_AUTH_MODE=azd
# MCP_TENANT_ID=<tenant-id>
# MCP_HTTP_TIMEOUT_SECONDS=45
# PBI_ORCH_SCHEMA_MAX_TABLES=12
# PBI_ORCH_QUERY_SCHEMA_TABLES=10
# PBI_ORCH_QUERY_MAX_ROWS=250
